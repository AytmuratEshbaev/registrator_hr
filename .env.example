# ============================================
# Supabase (Database + Auth)
# https://supabase.com — Project Settings → API
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================
# Cloudflare R2 (S3-compatible storage)
# https://dash.cloudflare.com → R2 → Manage R2 API Tokens
# ============================================
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=hr-registrator-files
# Endpoint format: https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT=https://your-cloudflare-account-id.r2.cloudflarestorage.com

# ============================================
# Cloudflare Turnstile (bot protection)
# https://dash.cloudflare.com → Turnstile
# Tip: use 1x00000000000000000000AA / 1x0000000000000000000000000000000AA
# as test keys during development (always pass)
# ============================================
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# ============================================
# App
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# Rate limiting (optional, defaults to in-memory)
# Get from https://upstash.com — Redis → REST API
# ============================================
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
